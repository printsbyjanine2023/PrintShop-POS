# Frontend
VITE_API_URL=http://localhost:5000
VITE_APP_NAME=PrintShop POS

# Backend
DATABASE_CONNECTION_STRING=Server=localhost;Database=PrintShop;Trusted_Connection=true;
JWT_SECRET=your-super-secret-key-min-32-characters-long
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800

# Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@printshop.com

# SMS (Twilio or similar)
SMS_ACCOUNT_SID=your-account-sid
SMS_AUTH_TOKEN=your-auth-token
SMS_FROM_NUMBER=+1234567890

# Payment Integration
GCASH_WEBHOOK_URL=https://your-domain.com/api/payments/gcash/webhook
MAYA_API_KEY=your-maya-api-key
BANK_API_KEY=your-bank-api-key

# Storage
CLOUD_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...
LOCAL_BACKUP_PATH=/backups

# Business Settings
CURRENCY=PHP
TAX_RATE=0.12
